{
  "name": "@example/rwsdk-todo",
  "version": "1.0.0",
  "description": "A real RedwoodSDK todo app driven by the Glean data system (SQLite Durable Object + GraphQL + compile-time reads)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "preview": "vite preview",
    "release": "vite build && wrangler deploy",
    "generate": "wrangler types --include-runtime false",
    "types": "tsc"
  },
  "dependencies": {
    "@gleanql/client": "workspace:*",
    "graphql": "^16.14.1",
    "kysely": "^0.28.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-server-dom-webpack": "19.2.6",
    "rwsdk": "1.2.11"
  },
  "devDependencies": {
    "@gleanql/vite": "workspace:*",
    "@cloudflare/vite-plugin": "1.33.2",
    "@cloudflare/workers-types": "4.20260426.1",
    "@types/node": "~25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3",
    "vite": "~7.3.2",
    "wrangler": "4.85.0"
  }
}
