{
  // Schema reference for wrangler configuration
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "glean-docs",
  "main": "src/worker.tsx",

  "compatibility_date": "2025-08-21",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "binding": "ASSETS"
  },

  "observability": {
    "enabled": true
  }
}
