{
  "name": "@gleanql/core",
  "version": "0.1.11",
  "description": "Glean's GraphQL operation IR: builder, merger, printer and schema model",
  "license": "MIT",
  "author": "Alexander Liljengard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gleanql/gleanql.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=4096 tsdown src/index.ts --format esm --dts.eager"
  },
  "homepage": "https://gleanql.com",
  "bugs": "https://github.com/gleanql/gleanql/issues",
  "keywords": [
    "graphql",
    "query-ir",
    "graphql-printer",
    "selection-merging"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
